<UserControl x:Class="WindowsHoneypot.UI.Controls.StatisticsDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="1200">
    
    <UserControl.Resources>
        <!-- Style for stat cards -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAccentBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="8" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="StatIconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Opacity" Value="0.95"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Mouse Clicks Card -->
        <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
            <StackPanel>
                <TextBlock Text="🖱️" Style="{StaticResource StatIconStyle}"/>
                <TextBlock Text="{Binding TotalMouseClicks}" 
                          Style="{StaticResource StatValueStyle}"/>
                <TextBlock Text="Mouse Clicks" 
                          Style="{StaticResource StatLabelStyle}"/>
            </StackPanel>
        </Border>
        
        <!-- Keystrokes Card -->
        <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
            <StackPanel>
                <TextBlock Text="⌨️" Style="{StaticResource StatIconStyle}"/>
                <TextBlock Text="{Binding TotalKeystrokes}" 
                          Style="{StaticResource StatValueStyle}"/>
                <TextBlock Text="Keystrokes" 
                          Style="{StaticResource StatLabelStyle}"/>
            </StackPanel>
        </Border>
        
        <!-- File Operations Card -->
        <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
            <StackPanel>
                <TextBlock Text="📁" Style="{StaticResource StatIconStyle}"/>
                <TextBlock Text="{Binding TotalFileOperations}" 
                          Style="{StaticResource StatValueStyle}"/>
                <TextBlock Text="File Operations" 
                          Style="{StaticResource StatLabelStyle}"/>
            </StackPanel>
        </Border>
        
        <!-- Screenshots Card -->
        <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
            <StackPanel>
                <TextBlock Text="📷" Style="{StaticResource StatIconStyle}"/>
                <TextBlock Text="{Binding TotalScreenshots}" 
                          Style="{StaticResource StatValueStyle}"/>
                <TextBlock Text="Screenshots" 
                          Style="{StaticResource StatLabelStyle}"/>
            </StackPanel>
        </Border>
        
        <!-- Risk Level Card -->
        <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
            <StackPanel>
                <TextBlock Text="⚠️" Style="{StaticResource StatIconStyle}"/>
                <TextBlock Text="{Binding RiskLevel}" 
                          Style="{StaticResource StatValueStyle}"
                          FontSize="22"/>
                <TextBlock Text="Risk Level" 
                          Style="{StaticResource StatLabelStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
