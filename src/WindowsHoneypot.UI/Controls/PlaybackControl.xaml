<UserControl x:Class="WindowsHoneypot.UI.Controls.PlaybackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="800">
    
    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
           BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
           BorderThickness="1"
           CornerRadius="8"
           Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Title -->
            <TextBlock Grid.Row="0" 
                      Text="🎮 Playback Controls" 
                      FontSize="14" 
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                      Margin="0,0,0,12"/>
            
            <!-- Progress Bar with Position -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                          Text="{Binding CurrentPosition}" 
                          FontFamily="Consolas"
                          FontSize="13"
                          FontWeight="Bold"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                          Margin="0,0,12,0"
                          MinWidth="40"
                          TextAlignment="Right"/>
                
                <Slider Grid.Column="1" 
                       Minimum="0" 
                       Maximum="{Binding TotalEntries}"
                       Value="{Binding CurrentPosition, Mode=TwoWay}"
                       TickFrequency="1"
                       IsSnapToTickEnabled="True"
                       VerticalAlignment="Center"
                       ui:ControlHelper.CornerRadius="4"/>
                
                <TextBlock Grid.Column="2" 
                          Text="{Binding TotalEntries}" 
                          FontFamily="Consolas"
                          FontSize="13"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                          Margin="12,0,0,0"
                          MinWidth="40"/>
            </Grid>
            
            <!-- Control Buttons -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Main Playback Buttons -->
                <StackPanel Grid.Column="0" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Left">
                    
                    <Button Command="{Binding PreviousEntryCommand}"
                           ToolTip="Previous Event"
                           Padding="10,6"
                           Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏮️" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="Previous" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding PlayCommand}"
                           ToolTip="Play Timeline"
                           Padding="12,6"
                           Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶️" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="Play" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding PauseCommand}"
                           ToolTip="Pause Playback"
                           Padding="12,6"
                           Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏸️" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="Pause" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding StopCommand}"
                           ToolTip="Stop and Reset"
                           Padding="10,6"
                           Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏹️" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="Stop" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding NextEntryCommand}"
                           ToolTip="Next Event"
                           Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Next" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock Text="⏭️" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Speed Controls -->
                <Border Grid.Column="1" 
                       BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                       BorderThickness="1"
                       CornerRadius="6"
                       Padding="12,6"
                       Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding DecreaseSpeedCommand}"
                               ToolTip="Decrease Playback Speed"
                               Padding="8,4"
                               Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🐌" FontSize="14" Margin="0,0,4,0"/>
                                <TextBlock Text="Slower" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        
                        <Border Background="{DynamicResource SystemControlBackgroundAccentBrush}"
                               CornerRadius="4"
                               Padding="12,4"
                               Margin="0,0,8,0">
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="Speed: " Foreground="White" FontSize="11"/>
                                <Run Text="{Binding PlaybackSpeed, StringFormat='{}{0:F1}x'}" 
                                     FontWeight="Bold" 
                                     Foreground="White"
                                     FontSize="12"/>
                            </TextBlock>
                        </Border>
                        
                        <Button Command="{Binding IncreaseSpeedCommand}"
                               ToolTip="Increase Playback Speed"
                               Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Faster" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="🚀" FontSize="14"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
