<Window x:Class="WindowsHoneypot.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:WindowsHoneypot.UI.ViewModels"
        Title="Windows Honeypot Solution" 
        Height="800" 
        Width="1200"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        ui:WindowHelper.UseModernWindowStyle="True">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundAccentBrush}" Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🍯" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Windows Honeypot Solution" 
                          FontSize="20" 
                          FontWeight="Bold" 
                          Foreground="White"
                          VerticalAlignment="Center"/>
                <TextBlock Text="v1.0.0" 
                          FontSize="12" 
                          Foreground="White"
                          Opacity="0.8"
                          VerticalAlignment="Bottom"
                          Margin="10,0,0,2"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Control Panel -->
            <Border Grid.Column="0" 
                   Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                   CornerRadius="8"
                   Padding="20"
                   Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Control Panel" 
                              FontSize="16" 
                              FontWeight="Bold" 
                              Margin="0,0,0,20"/>
                    
                    <!-- Protection Status -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Protection Status" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ui:ToggleSwitch Header="Honeypot Active"
                                        OnContent="ON"
                                        OffContent="OFF"
                                        IsOn="{Binding IsProtectionEnabled, Mode=TwoWay}"
                                        Toggled="ProtectionToggle_Toggled"/>
                    </StackPanel>
                    
                    <!-- Statistics -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Statistics" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Attacks Blocked:" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AttacksBlocked}" FontWeight="Bold" Margin="0,2"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Files Monitored:" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FilesMonitored}" FontWeight="Bold" Margin="0,2"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Uptime:" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Uptime}" FontWeight="Bold" Margin="0,2"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- Quick Actions -->
                    <StackPanel>
                        <TextBlock Text="Quick Actions" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Button Content="Configure Bait Folder" 
                               Margin="0,2" 
                               HorizontalAlignment="Stretch"
                               Command="{Binding ConfigureBaitFolderCommand}"/>
                        <Button Content="View Logs" 
                               Margin="0,2" 
                               HorizontalAlignment="Stretch"
                               Command="{Binding ViewLogsCommand}"/>
                        <Button Content="Export Report" 
                               Margin="0,2" 
                               HorizontalAlignment="Stretch"
                               Command="{Binding ExportReportCommand}"/>
                        <Button Content="Emergency Cleanup" 
                               Margin="0,2" 
                               HorizontalAlignment="Stretch" 
                               Background="{DynamicResource SystemControlBackgroundAccentBrush}"
                               Command="{Binding EmergencyCleanupCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Main Dashboard -->
            <Border Grid.Column="1" 
                   Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                   CornerRadius="8"
                   Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Dashboard Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Real-time Activity Monitor" 
                                  FontSize="16" 
                                  FontWeight="Bold" 
                                  VerticalAlignment="Center"/>
                        <Border Background="{DynamicResource SystemControlBackgroundAccentBrush}" 
                               CornerRadius="12" 
                               Padding="8,4" 
                               Margin="20,0,0,0">
                            <TextBlock Text="{Binding StatusIndicator}" 
                                      Foreground="White" 
                                      FontSize="12" 
                                      FontWeight="Bold"/>
                        </Border>
                        
                        <!-- System Status Indicators -->
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                   CornerRadius="8" 
                                   Padding="8,4" 
                                   Margin="0,0,5,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🖥️" FontSize="12" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding SystemStatus}" FontSize="11"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                   CornerRadius="8" 
                                   Padding="8,4" 
                                   Margin="0,0,5,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦" FontSize="12" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding SandboxStatus}" FontSize="11"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                   CornerRadius="8" 
                                   Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌐" FontSize="12" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding NetworkStatus}" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Activity Log -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Search and Filter Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Search Box Row -->
                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBox Grid.Column="0" 
                                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                        ui:ControlHelper.PlaceholderText="Search logs by description, process, or target..."
                                        Margin="0,0,5,0"/>
                                <Button Grid.Column="1" 
                                       Content="🔍 Search" 
                                       Padding="10,5"
                                       Margin="0,0,5,0"
                                       Command="{Binding SearchLogsCommand}"/>
                                <Button Grid.Column="2" 
                                       Content="Clear" 
                                       Padding="10,5"
                                       Command="{Binding ClearSearchCommand}"/>
                            </Grid>
                            
                            <!-- Filter ComboBoxes Row -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" 
                                          Text="Event Type:" 
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"/>
                                <ComboBox Grid.Column="1"
                                         ItemsSource="{Binding EventTypeFilters}"
                                         SelectedItem="{Binding SelectedEventTypeFilter, Mode=TwoWay}"
                                         ui:ControlHelper.PlaceholderText="All Types"
                                         DisplayMemberPath="."
                                         SelectedValuePath="."/>
                                
                                <TextBlock Grid.Column="3" 
                                          Text="Severity:" 
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"/>
                                <ComboBox Grid.Column="4"
                                         ItemsSource="{Binding SeverityFilters}"
                                         SelectedItem="{Binding SelectedSeverityFilter, Mode=TwoWay}"
                                         ui:ControlHelper.PlaceholderText="All Severities"
                                         DisplayMemberPath="."
                                         SelectedValuePath="."/>
                                
                                <TextBlock Grid.Column="5"
                                          Text="{Binding AttackEvents.Count, StringFormat='Showing {0} events'}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Right"
                                          FontSize="11"
                                          Opacity="0.7"
                                          Margin="10,0,0,0"/>
                            </Grid>
                        </Grid>
                        
                        <DataGrid Grid.Row="1"
                                 ItemsSource="{Binding AttackEvents}"
                                 AutoGenerateColumns="False"
                                 CanUserAddRows="False"
                                 CanUserDeleteRows="False"
                                 IsReadOnly="True"
                                 GridLinesVisibility="Horizontal"
                                 HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="80"/>
                                <DataGridTextColumn Header="Event Type" Binding="{Binding EventType}" Width="120"/>
                                <DataGridTextColumn Header="Process" Binding="{Binding SourceProcess}" Width="120"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding TargetFile}" Width="200"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Separator -->
                    <Border Grid.Row="2" 
                           Height="1" 
                           Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" 
                           Margin="0,10"/>

                    <!-- Credential Attempts Section -->
                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="🎣 Honey Account Access Attempts" 
                                      FontSize="14" 
                                      FontWeight="Bold" 
                                      VerticalAlignment="Center"/>
                            <Border Background="#DC3545" 
                                   CornerRadius="10" 
                                   Padding="6,2" 
                                   Margin="10,0,0,0">
                                <TextBlock Text="{Binding CredentialAttemptsCount}" 
                                          Foreground="White" 
                                          FontSize="11" 
                                          FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <DataGrid Grid.Row="1" 
                                 ItemsSource="{Binding CredentialAttempts}"
                                 AutoGenerateColumns="False"
                                 CanUserAddRows="False"
                                 CanUserDeleteRows="False"
                                 IsReadOnly="True"
                                 GridLinesVisibility="Horizontal"
                                 HeadersVisibility="Column"
                                 SelectionMode="Single"
                                 MouseDoubleClick="CredentialAttemptsDataGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="140"/>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120"/>
                                <DataGridTextColumn Header="IP Address" Binding="{Binding IPAddress}" Width="120"/>
                                <DataGridTextColumn Header="Browser" Binding="{Binding Browser}" Width="100"/>
                                <DataGridTextColumn Header="OS" Binding="{Binding OperatingSystem}" Width="100"/>
                                <DataGridTextColumn Header="Resolution" Binding="{Binding ScreenResolution}" Width="100"/>
                                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="2" 
               Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
               Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                          Text="{Binding StatusMessage}"
                          VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Fill" Value="LimeGreen"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsProtectionEnabled}" Value="True">
                                        <Setter Property="Fill" Value="Orange"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disconnected"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Text" Value="Active"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsProtectionEnabled}" Value="True">
                                        <Setter Property="Text" Value="Connected"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>